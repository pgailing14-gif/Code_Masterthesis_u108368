        // ---------------------------------------------------------------------
        // Marker und Linien für Zeitpunkt 3 (2026)
        // Erstellt die Marker für die Identitätsräume und die Linien für die Kooperationsachsen
        // Die Grundstruktur dieser Funktion wurde unter Nutzung integrierter Funktionen der Entwicklungsumgebung erstellt und anschließend eigenständig angepasst
        // ---------------------------------------------------------------------
        function loadKoordinatenMarkers() {
            // Marker für die Städte werden erstellt
            const markers = cities.map(city => {
                // Straßburg und Karlsruhe bekommen einen größeren Marker, da beide Städte wichtige Knotenpunkte sind
                let markerRadius = 10;
                if (city.name === 'Straßburg' || city.name === 'Karlsruhe') {
                    markerRadius = 14;
                }

                // Farbe wird basierend auf dem Identitätsraum-Typ zugewiesen
                return L.circleMarker(city.coords, {
                    radius: markerRadius,
                    fillColor: identityColors[city.type],
                    color: identityColors[city.type],
                    weight: 0,
                    fillOpacity: 0.85
                }).bindPopup(
                    // Popup-Inhalt: Stadtname, Identitätsraum-Typ und Infotext
                    '<b>' + city.name + ' (2026)</b><br><br>' +
                    '<b>Identitätsraum-Typ:</b> ' + city.type + '<br><br>' +
                    city.text
                );
            });

            // Die Marker werden in einer Gruppe zusammengefasst
            koordinatenMarkerLayer = L.layerGroup(markers);

            // Kooperationsachsen zwischen den Städten werden definiert
            const achsen = [
                { from: [49.0069, 8.4037], to: [48.5839, 7.7455], label: 'Karlsruhe \u2013 Stra\u00dfburg',
                  info: '<b>Oberrhein-Kooperationsachse</b><br>• Grenz\u00fcberschreitende Verwaltungskooperation<br>• INTERREG-Programme / EU-F\u00f6rderprojekte<br>• Wissenschaft &amp; Hochschulnetzwerke<br>• Justizielle Institutionen (u.a. europ\u00e4ische Bez\u00fcge)' },
                { from: [49.0069, 8.4037], to: [48.5720, 7.8157], label: 'Karlsruhe \u2013 Kehl',
                  info: '<b>Infrastrukturelle Anbindung</b><br>• Verkehrsknoten Oberrhein<br>• Wirtschaftsverflechtung<br>• Regionalplanung Baden\u2013Elsass' },
                { from: [48.5839, 7.7455], to: [48.5720, 7.8157], label: 'Stra\u00dfburg \u2013 Kehl',
                  info: '<b>Unmittelbarer Grenzraum</b><br>• Allt\u00e4glicher Grenzverkehr<br>• Gemeinsame Stadtentwicklung<br>• Tram-Verbindung \u00fcber den Rhein<br>• Arbeitsmarkt- und Bildungsbeziehungen' },
                { from: [48.5839, 7.7455], to: [48.0794, 7.3585], label: 'Stra\u00dfburg \u2013 Colmar',
                  info: '<b>Els\u00e4ssische Achse</b><br>• Regionale Wirtschaftsstruktur<br>• Tourismus- und Kulturlandschaft<br>• Verwaltung im Rahmen Grand Est' },
                { from: [49.2402, 6.9969], to: [49.1193, 6.1757], label: 'Saarbr\u00fccken \u2013 Metz',
                  info: '<b>Gro\u00dfregion SaarLorLux</b><br>• Grenz\u00fcberschreitender Arbeitsmarkt<br>• Industrie- und Energieraum<br>• Politische Kooperation Gro\u00dfregion<br>• Historisch gepr\u00e4gte Verflechtungen' }
            ];

            const achsenElements = [];
            const achsenMarkerCoords = {};

            // Verbindungslinie wird erstellt und Endpunkt-Koordinaten merken
            achsen.forEach(a => {
                // Polyline = Verbindungslinie zwischen den beiden Städten
                achsenElements.push(L.polyline([a.from, a.to], {
                    color: '#555555',
                    weight: 1.5,
                    opacity: 0.6
                }).bindPopup('<strong>' + a.label + '</strong><br><br>' + a.info));

                // Endpunkt speichern; nur einmal pro Stadt
                achsenMarkerCoords[a.from.toString()] = a.from;
                achsenMarkerCoords[a.to.toString()] = a.to;
            });

            // Pro Stadt einen Marker erstellen und setzen
            Object.values(achsenMarkerCoords).forEach(coord => {
                // Marker zur passenden Stadt suchen
                const city = cities.find(c => c.coords[0] === coord[0] && c.coords[1] === coord[1]);
                if (city) {
                    achsenElements.push(L.circleMarker(coord, {
                        radius: 6,
                        fillColor: '#4F4F4F',
                        color: '#4F4F4F',
                        weight: 1,
                        fillOpacity: 0.8
                    }).bindPopup('<b>' + city.name + '</b>'));
                }
            });

            // Alle Achsen-Elemente in einer LayerGroup zusammenfassen
            kooperationsachsenLayer = L.layerGroup(achsenElements);

            // Layer-Kontrolle für Zeitpunkt 3 aktualisieren
            refreshZeitpunkt3LayerControl(parseInt(timeRange.value, 10));
            if (rheinLayer) rheinLayer.bringToFront();

            // Konsolenausgabe zur Überprüfung
            console.log('Identitätsraum-Marker geladen:', markers.length);
            console.log('Kooperationsachsen geladen:', achsenElements.length);
        }

        // ---------------------------------------------------------------------
        // TimeSlider
        // Sowohl das Label als auch die angezeigten Layer, Infoboxen und Legenden werden je nach Zeitpunkt aktualisiert
        // ---------------------------------------------------------------------
        timeRange.addEventListener('input', function () {
            const zeitpunkt = parseInt(this.value, 10);
            timeLabel.textContent = zeitpunktLabels[zeitpunkt] || zeitpunkt;
            console.log('Wechsel zu Zeitpunkt:', zeitpunkt);

            refreshZeitpunkt1LayerControl(zeitpunkt);
            refreshZeitpunkt2Layers(zeitpunkt);
            refreshZeitpunkt3LayerControl(zeitpunkt);
            refreshZeitpunkt1InfoBox(zeitpunkt);
            refreshZeitpunkt2InfoBox(zeitpunkt);
            refreshZeitpunkt3InfoBox(zeitpunkt);
            refreshZeitpunkt1Legend(zeitpunkt);
            refreshZeitpunkt2Legend(zeitpunkt);
            refreshZeitpunkt3Legend(zeitpunkt);
        });

        // ---------------------------------------------------------------------
        // Layer Auswahl
        // Ein- und Ausblenden der Layer anhand des Layer-Controls, passt dementsprechend die Darstellung und Legende an
        // ---------------------------------------------------------------------
        map.on('overlayadd overlayremove', function (event) {
            const zeitpunkt = parseInt(timeRange.value, 10);

            if (zeitpunkt === 1) {
                if (event.layer === elsass1871ToggleLayer || event.layer === deutschesReich1871ToggleLayer) {
                    syncZeitpunkt1StyleFromControl();
                    if (rheinLayer) rheinLayer.bringToFront();
                }
            }

            if (zeitpunkt === 3) {
                if (event.layer === koordinatenToggleLayer || event.layer === kooperationsachsenToggleLayer) {
                    syncZeitpunkt3LayersFromControl();
                    refreshZeitpunkt3Legend(3);
                    if (rheinLayer) rheinLayer.bringToFront();
                }
            }
        });

        // ---------------------------------------------------------------------
        // Maßstab: Fügt einen Maßstab zur Orientierung ein; Positionierung: unten rechts
        // ---------------------------------------------------------------------
        L.control.scale({
            position: 'bottomright',
            metric: true,
            imperial: false
        }).addTo(map);

        // ---------------------------------------------------------------------
        // GeoJSON-Layer werden geladen
        // Die GeoJSON-Daten werden geladen und als Layer der Karte hinzugefügt
        // Je nach Zeitpunkt werden die dazugehörigen Layer angezeigt bzw. ausgeblendet
        // ---------------------------------------------------------------------
        function loadLayers() {

            // -----------------------------------------------------------------
            // Darstellung für Deutschland (Zeitpunkt 3)
            // Neutraler Stil in der Darstellung
            // Die Struktur basiert auf einem wiederkehrenden Muster für das Laden und Einbinden von GeoJSON-Daten
            // Dieses Muster wurde unter Nutzung integrierter Funktionen der Entwicklungsumgebung im Rahmen der Entwicklung erstellt und auf weitere Layer eigenständig angepasst
            // -----------------------------------------------------------------
            fetch('deutschland.json')
                .then(response => response.json())
                .then(data => {
                    deutschlandLayer = L.geoJSON(data, {
                        style: {
                            color: '#a4a8aa',
                            weight: 1,
                            opacity: 1,
                            fillColor: '#FFFFFF',
                            fillOpacity: 0.5
                        }
                    }).addTo(map);
                    // Anzeige aktualisieren
                    refreshZeitpunkt3LayerControl(parseInt(timeRange.value, 10));
                    refreshZeitpunkt2Layers(parseInt(timeRange.value, 10));
                    if (rheinLayer) rheinLayer.bringToFront();
                    console.log('Deutschland GeoJSON geladen');
                })
                .catch(error => console.error('Fehler beim Laden der Deutschland-Daten:', error));

            // -----------------------------------------------------------------
            // Darstellung für Elsass (für Zeitpunkt 3)
            // Gleicher Stil wie Deutschland
            // -----------------------------------------------------------------
            fetch('elsass.json')
                .then(response => response.json())
                .then(data => {
                    elsassLayer = L.geoJSON(data, {
                        style: {
                            color: '#a4a8aa',
                            weight: 1,
                            opacity: 1,
                            fillColor: '#FFFFFF',
                            fillOpacity: 0.5
                        }
                    }).addTo(map);
                    refreshZeitpunkt3LayerControl(parseInt(timeRange.value, 10));
                    refreshZeitpunkt2Layers(parseInt(timeRange.value, 10));
                    if (rheinLayer) rheinLayer.bringToFront();
                    console.log('Elsass GeoJSON geladen');
                })
                .catch(error => console.error('Fehler beim Laden der Elsass-Daten:', error));

            // -----------------------------------------------------------------
            // Darstellung für Elsass 1871 (Zeitpunkt 1)
            // Darstellung mit Pop-Ups zu Name und Stimmungsindex
            // -----------------------------------------------------------------
            fetch('elsass_1871.geojson')
                .then(response => response.json())
                .then(data => {
                    elsass1871Layer = L.geoJSON(data, {
                        style: getNeutralFeatureStyle(),
                        onEachFeature: (feature, layer) => {
                            // Name und Stimmungsindex ermitteln
                            const dep = feature?.properties?.NOM_DEP || 'Unbekannt';
                            const key = String(dep).toUpperCase();
                            const score = Object.prototype.hasOwnProperty.call(elsass1871ScoreByDepartment, key)
                                ? elsass1871ScoreByDepartment[key]
                                : 'k.A.';
                            layer.bindPopup('<strong>' + dep + '</strong><br>Stimmungsindex: ' + score);
                        }
                    });
                    refreshZeitpunkt1LayerControl(parseInt(timeRange.value, 10));
                    console.log('Elsass 1871 GeoJSON geladen');
                })
                .catch(error => console.error('Fehler beim Laden der Elsass-1871-Daten:', error));

            // -----------------------------------------------------------------
            // Darstellung für Deutsches Reich 1871 (Zeitpunkt 1)
            // Darstellung mit Pop-Ups zu Name und Stimmungsindex
            // -----------------------------------------------------------------
            fetch('DeutschesReich_1871.geojson')
                .then(response => response.json())
                .then(data => {
                    deutschesReich1871Layer = L.geoJSON(data, {
                        style: getNeutralFeatureStyle(),
                        onEachFeature: (feature, layer) => {
                            // Name und Stimmungsindex ermitteln
                            const name = feature?.properties?.GEN || 'Unbekannt';
                            const score = feature?.properties?.Stimmungsindex ?? 'k.A.';
                            layer.bindPopup('<strong>' + name + '</strong><br>Stimmungsindex: ' + score);
                        }
                    });
                    refreshZeitpunkt1LayerControl(parseInt(timeRange.value, 10));
                    console.log('Deutsches Reich 1871 GeoJSON geladen');
                })
                .catch(error => console.error('Fehler beim Laden der Deutsches-Reich-1871-Daten:', error));

            // -----------------------------------------------------------------
            // Darstellung für Deutsches Reich 1900 (Zeitpunkt 2)
            // Neutrale Darstellung
            // -----------------------------------------------------------------
            fetch('DeutschesReich_1900.geojson')
                .then(response => response.json())
                .then(data => {
                    deutschesReich1900Layer = L.geoJSON(data, {
                        style: {
                            color: '#a4a8aa',
                            weight: 0.5,
                            opacity: 1,
                            fillColor: '#FFFFFF',
                            fillOpacity: 0.5
                        }
                    }).addTo(map);
                    refreshZeitpunkt2Layers(parseInt(timeRange.value, 10));
                    if (rheinLayer) rheinLayer.bringToFront();
                    console.log('Deutsches Reich 1900 GeoJSON geladen');
                })
                .catch(error => console.error('Fehler beim Laden der Deutsches-Reich-1900-Daten:', error));

            // -----------------------------------------------------------------
            // Darstellung für Elsass-Lothringen 1900 (Zeitpunkt 2)
            // Neutrale Darstellung
            // -----------------------------------------------------------------
            fetch('Elsass_Lothringen_1900.geojson')
                .then(response => response.json())
                .then(data => {
                    elsassLothringen1900Layer = L.geoJSON(data, {
                        style: {
                            color: '#a4a8aa',
                            weight: 0.5,
                            opacity: 1,
                            fillColor: '#FFFFFF',
                            fillOpacity: 0.5
                        }
                    }).addTo(map);
                    refreshZeitpunkt2Layers(parseInt(timeRange.value, 10));
                    if (rheinLayer) rheinLayer.bringToFront();
                    console.log('Elsass-Lothringen 1900 GeoJSON geladen');
                })
                .catch(error => console.error('Fehler beim Laden der Elsass-Lothringen-1900-Daten:', error));

            // -----------------------------------------------------------------
            // Neue Staatsgrenze (Zeitpunkt 1 und 2)
            // Darstellung der historischen Grenzlinie
            // -----------------------------------------------------------------
            fetch('Grenze_1900.geojson')
                .then(response => response.json())
                .then(data => {
                    grenze1900Layer = L.geoJSON(data, {
                        style: {
                            color: '#555555',
                            weight: 2.5,
                            opacity: 1
                        }
                    }).addTo(map);
                    refreshZeitpunkt2Layers(parseInt(timeRange.value, 10));
                    if (rheinLayer) rheinLayer.bringToFront();
                    console.log('Grenze 1900 GeoJSON geladen');
                })
                .catch(error => console.error('Fehler beim Laden der Grenze-1900-Daten:', error));

            // -----------------------------------------------------------------
            // Grenzbahnhöfe (Zeitpunkt 2)
            // Bahnhöfe werden mit Markern dargestellt; farbliche Unterteilung nach Kategorie
            // -----------------------------------------------------------------
            fetch('grenzbahnhoefe_1900.geojson')
                .then(response => response.json())
                .then(data => {
                    grenzbahnhoefe1900Layer = L.geoJSON(data, {
                        pointToLayer: function (feature, latlng) {
                            // Eigenschaften des Pointfeatures auslesen
                            const properties = feature?.properties || {};
                            const name = properties.Name || 'Unbekannt';

                            // Kategorisierung der Bahnhöfe
                            const categoryValue = feature?.properties?.Kategorie ?? feature?.properties?.kategorie ?? '';
                            const category = String(categoryValue).trim().toLowerCase();
                            const categoryLabel = properties.Kategorie || properties.kategorie || 'Unbekannt';

                            // Informationstext
                            const funktion = properties.Funktion || 'Keine Zusatzinformation verfügbar';

                            // Darstellung nach Kategorie
                            let markerFillColor = '#A80000';
                            if (category === 'grenzbahnhof') {
                                markerFillColor = '#66c2a4';
                            } else if (category === 'verkehrszentrum') {
                                markerFillColor = '#A80000';
                            }

                            const marker = L.circleMarker(latlng, {
                                radius: 5,
                                fillColor: markerFillColor,
                                color: markerFillColor,
                                weight: 0,
                                opacity: 1,
                                fillOpacity: 0.85
                            });

                            // Pop-Up mit Zusatzinformationen zum Bahnhof
                            marker.bindPopup(
                                '<strong style="font-size:14px">' + name + '</strong><br>' +
                                '<strong>' + categoryLabel + '</strong> ' + '<br>' +
                                '<strong>Funktion:</strong> ' + funktion
                            );

                            return marker;
                        }
                    }).addTo(map);
                    refreshZeitpunkt2Layers(parseInt(timeRange.value, 10));
                    if (rheinLayer) rheinLayer.bringToFront();
                    console.log('Grenzbahnhöfe 1900 GeoJSON geladen');
                })
                .catch(error => console.error('Fehler beim Laden der Grenzbahnhöfe-1900-Daten:', error));

            // -----------------------------------------------------------------
            // Bahnnetz (Zeitpunkt 2)
            // Generalisierte Darstellung des Bahnnetzes um 1900
            // -----------------------------------------------------------------
            fetch('Bahnnetz.geojson')
                .then(response => response.json())
                .then(data => {
                    bahnnetzLayer = L.geoJSON(data, {
                        style: {
                            color: '#888888',
                            weight: 1.5,
                            opacity: 0.6
                        }
                    }).addTo(map);
                    refreshZeitpunkt2Layers(parseInt(timeRange.value, 10));
                    if (rheinLayer) rheinLayer.bringToFront();
                    console.log('Bahnnetz GeoJSON geladen');
                })
                .catch(error => console.error('Fehler beim Laden der Bahnnetz-Daten:', error));

            // -----------------------------------------------------------------
            // Rhein (alle Zeitpunkte)
            // Ist in der Hierachie ganz oben und wird immer dargestellt -> Orientierungspunkt in der Karte
            // -----------------------------------------------------------------
            fetch('rhein.geojson')
                .then(response => response.json())
                .then(data => {
                    rheinLayer = L.geoJSON(data, {
                        style: {
                            color: '#1C86EE',
                            weight: 3.0,
                            opacity: 0.8
                        }
                    }).addTo(map);
                    rheinLayer.bringToFront(); // Immer ganz oben

                    // Anzeige für den aktuellen Zeitpunkt initialisieren
                    refreshZeitpunkt1LayerControl(parseInt(timeRange.value, 10));
                    refreshZeitpunkt2Layers(parseInt(timeRange.value, 10));
                    refreshZeitpunkt3LayerControl(parseInt(timeRange.value, 10));
                    refreshZeitpunkt1InfoBox(parseInt(timeRange.value, 10));
                    refreshZeitpunkt2InfoBox(parseInt(timeRange.value, 10));
                    refreshZeitpunkt3InfoBox(parseInt(timeRange.value, 10));
                    refreshZeitpunkt1Legend(parseInt(timeRange.value, 10));
                    refreshZeitpunkt2Legend(parseInt(timeRange.value, 10));
                    refreshZeitpunkt3Legend(parseInt(timeRange.value, 10));
                    console.log('Rhein GeoJSON geladen');
                })
                .catch(error => console.error('Fehler beim Laden der Rhein-Daten:', error));

            // -----------------------------------------------------------------
            // Oberrheingraben (Zeitpunkt 3 / Kooperationsachsen)
            // Darstellung als transparente Fläche 
            // -----------------------------------------------------------------
            fetch('Oberrheingraben.geojson')
                .then(response => response.json())
                .then(data => {
                    oberrheingrabenLayer = L.geoJSON(data, {
                        interactive: false,
                        style: {
                            color: '#fe9929',
                            weight: 0,
                            opacity: 0,
                            fillColor: '#fe9929',
                            fillOpacity: 0.25
                        }
                    });
                    refreshZeitpunkt3LayerControl(parseInt(timeRange.value, 10));
                    console.log('Oberrheingraben GeoJSON geladen');
                })
                .catch(error => console.error('Fehler beim Laden der Oberrheingraben-Daten:', error));

            // -----------------------------------------------------------------
            // SaarLorLux-Region (Zeitpunkt 3 / Kooperationsachsen)
            // Darstellung als transparente Fläche
            // -----------------------------------------------------------------
            fetch('SaarLorLux_Region.geojson')
                .then(response => response.json())
                .then(data => {
                    saarLorLuxLayer = L.geoJSON(data, {
                        interactive: false,
                        filter: function (feature) {
                            // relevante Teilräume herausfiltern
                            var entity = (feature.properties && feature.properties.de_entity) || '';
                            var region = (feature.properties && feature.properties.region) || '';
                            if (region === 'SL') return entity === 'Gemeinde';
                            if (region === 'LUX') return entity === 'Kanton';
                            if (region === 'WAL') return entity === 'Gemeinde';
                            return !region || region === 'null';
                        },
                        style: {
                            color: '#fb6a4a',
                            weight: 0,
                            opacity: 0,
                            fillColor: '#fb6a4a',
                            fillOpacity: 0.25
                        }
                    });
                    refreshZeitpunkt3LayerControl(parseInt(timeRange.value, 10));
                    console.log('SaarLorLux Region GeoJSON geladen');
                })
                .catch(error => console.error('Fehler beim Laden der SaarLorLux-Daten:', error));
        }

        //----------------------------------------------------------------------
        // Initialisierung: Die Layer werden geladen und die Anzeige für den Startzeitpunkt wird auf 1871 gesetzt
        //----------------------------------------------------------------------
        loadLayers();
        loadKoordinatenMarkers();
    </script>
</body>
</html>
