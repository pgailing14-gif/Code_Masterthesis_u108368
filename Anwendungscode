                // Rhein-Symbol (nur wenn mindestens ein Layer aktiv)
                if (koordinatenActive || achsenActive) {
                    html += '<hr style="margin:8px 0">' +
                        '<strong>Weitere Kartenelemente</strong>' +
                        '<div class="legend-item"><span style="display:inline-block;width:20px;height:2px;background:#1a5276;margin-right:8px;vertical-align:middle;flex:0 0 20px"></span>Rhein</div>';
