        // ---------------------------------------------------------------------
        function refreshZeitpunkt3Legend(zeitpunkt) {
            if (zeitpunkt3LegendControl) {
                map.removeControl(zeitpunkt3LegendControl);
                zeitpunkt3LegendControl = null;
            }

            if (zeitpunkt !== 3) return;

            // Aktuellen Zustand prüfen
            const koordinatenActive = !!(koordinatenToggleLayer && map.hasLayer(koordinatenToggleLayer));
            const achsenActive = !!(kooperationsachsenToggleLayer && map.hasLayer(kooperationsachsenToggleLayer));

            zeitpunkt3LegendControl = L.control({ position: 'bottomleft' });
            zeitpunkt3LegendControl.onAdd = function () {
                const div = L.DomUtil.create('div', 'legend-box');
                let html = '';

                if (koordinatenActive) {
                    html += '<strong>Identitätsräume im deutsch-französischen Grenzraum (2026)</strong>' +
                        '<div class="legend-item"><span class="legend-swatch" style="background:' + identityColors['Europäisch-institutionell'] + '"></span>Europäisch-institutionell</div>' +
