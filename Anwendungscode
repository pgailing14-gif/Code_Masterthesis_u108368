    --------------------------------------------------------------------- -->

<!DOCTYPE html>
<html>
<head>
    <!-- ---------------------------------------------------------------------
         Kartentitel wird festgelegt, wie er auch im Browser-Tab angezeigt wird
         Seitentitel wird definiert & Zeichensatz (UTF-8 für Umlaute) festgelegt
         --------------------------------------------------------------------- -->
    <title>Deutsch-französischer Grenzraum im Wandel (1871–2026)</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- ---------------------------------------------------------------------
         Leaflet-CSS: Korrekte Darstellung der Karte
         --------------------------------------------------------------------- -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.7.1/dist/leaflet.css" />

    <!-- ---------------------------------------------------------------------
         CSS-Style
         Alle Styles für Karte, Time-Slider, Legende, Titel usw.
         --------------------------------------------------------------------- -->
    <style>
        /* Grundeinstellungen: Entfernt die Standardränder und Innenabstände, die Scrollbar ist deaktiviert */
        html, body {
            margin: 0;
            padding: 0;
            overflow: hidden;
        }

        /* Die Karte füllt die gesamte Fensterhöhe (100vh = 100% Viewport-Höhe) */
        #map {
            height: 100vh;
            position: relative;
        }

        /* Time-Slider: Die Position ist fest am unteren Bildschirmrand zentriert, Farbe: weißer Hintergrund mit Schattierung */
        .time-slider {
            position: fixed;
            left: 50%;
            bottom: 20px;
            transform: translateX(-50%); 
            background-color: white;
            padding: 10px;
            border-radius: 5px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.3);
            z-index: 1000;
        }

        /* Legende und Infoboxen: Einheitliche Darstellung mit weißem Hintergrund und Schattierung; entspricht für alle drei Zeitabschnitte*/
        .legend-box {
            background: white;
            padding: 10px;
            border-radius: 5px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.3);
            line-height: 1.4;
            font-size: 12px;
        }

        /* Einzelne Legendeneinträge: Einstellungen für die Anordnung von Farbfeld und Beschriftung */
        .legend-item {
            display: flex;
            align-items: center;
            margin-top: 4px;
        }

        /* Farbfeld innerhalb der Legende */
        .legend-swatch {
            width: 12px;
            height: 12px;
            margin-right: 8px;
            border: none;
            flex: 0 0 12px;
        }

        /* Kartentitel: Position & visuelle Gestaltung */
        .map-title {
            background: rgba(255,255,255,0.9);
            padding: 10px 18px;
            border-radius: 5px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.3);
            text-align: center;
            font-family: Arial, Helvetica, sans-serif;
        }

        /* Haupt- und Untertitel der Karte */
        .map-title h1 {
            margin: 0;
            font-size: 16px;
            font-weight: bold;
            color: #333;
        }
        .map-title h2 {
            margin: 4px 0 0 0;
            font-size: 12px;
            font-weight: normal;
            color: #666;
        }
    </style>
</head>
<body>
    <!-- ---------------------------------------------------------------------
         Karten-Container:
         Einbindung des HTML-Elements in die interaktive Leaflet-Karte
         --------------------------------------------------------------------- -->
    <div id="map"></div>

    <!-- Leaflet-JavaScript-Bibliothek: Stellt die Kartenfunktionalität bereit -->
    <script src="https://unpkg.com/leaflet@1.7.1/dist/leaflet.js"></script>

    <script>
        // ---------------------------------------------------------------------
        // Initialisierung der Leaflet-Karte
        // Erstellung der Leaflet-Karte ohne Standard-Zoom-Steuerung
        // Die Karte wird zentriert auf [48.6, 7.5], was ungefähr Oberrheingebiet entspricht
        // ---------------------------------------------------------------------
        const map = L.map('map', { zoomControl: false, maxZoom: 9 }).setView([48.6, 7.5], 7);

        // ---------------------------------------------------------------------
        // Die Basiskarte verwendet den hellen CARTO-Kartenstil als Hintergrund
        // ---------------------------------------------------------------------
        const baseLayer = L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; OpenStreetMap contributors &copy; CARTO'
        }).addTo(map);

        // ---------------------------------------------------------------------
        // Kartentitel: Positionierung links oben
        // Erstellt ein benutzerdefiniertes Leaflet-Control-Element mit Haupt- und Untertitel der Karte, ebenfalls oben links
        // ---------------------------------------------------------------------
        const titleControl = L.control({ position: 'topleft' });
        titleControl.onAdd = function (map) {
            const div = L.DomUtil.create('div', 'map-title');
            div.innerHTML = `
                <h1>Der deutsch-französische Grenzraum im historischen Wandel</h1>
                <h2>Interaktive Analyse von Grenzverschiebung, Infrastruktur und Kooperation (1871–2026)</h2>
            `;
            return div;
        };
        titleControl.addTo(map);

        // ---------------------------------------------------------------------
        // TimeSlider: Insgesamt drei Positionen; 
        // 1 = 1871, 2 = ca. 1900 & 3 = 2026
        // ---------------------------------------------------------------------
        const timeSlider = L.control({ position: 'bottomleft' });

        timeSlider.onAdd = function (map) {
            const div = L.DomUtil.create('div', 'time-slider');
            div.innerHTML = `
                <div style="display: flex; align-items: center; gap: 8px;">
                    <input id="timeRange" type="range" min="1" max="3" step="1" value="1" style="width: 200px;">
                    <label for="timeRange"><span id="timeLabel" style="display:inline-block;width:47px;text-align:center;">1</span></label>
                </div>
            `;
            // Verhindert eine Interaktion mit dem TimeSlider mit der darunterliegenden Karte
            L.DomEvent.disableClickPropagation(div);
            return div;
        };

        timeSlider.addTo(map);

        // ---------------------------------------------------------------------
        // Slider und Zuordnung der Zeitpunkte
        // Ordnet die Werte des SLiders den entsprechenden Zeitpunkten zu
        // ---------------------------------------------------------------------
        const timeRange = document.getElementById('timeRange');
        const timeLabel = document.getElementById('timeLabel');
        const zeitpunktLabels = {
            1: '1871',
            2: 'ca. 1900',
            3: '2026'
        };

        // Initialisierung des TimeSliders (beim Laden der Seite = Zeitpunkt 1 = "1871")
        timeLabel.textContent = zeitpunktLabels[parseInt(timeRange.value, 10)] || '1';

        // ---------------------------------------------------------------------
        // Layer-Variablen
        // Definiert Variablen für Layer und Steuerelemente, die im weiteren Verlauf verwendet werden
        // ---------------------------------------------------------------------

        // --- Steuerelemente für die verschiedenen Zeitpunkte (Layer-Auswahl, Info, Legende) ---
        let layerControl;
        let zeitpunkt1InfoControl;
        let zeitpunkt2InfoControl;
        let zeitpunkt3InfoControl;
        let zeitpunkt1LegendControl;
        let zeitpunkt2LegendControl;
        let zeitpunkt3LegendControl;

        // --- GeoJSON-Layer (Polygone, Linien, Punkte) ---
        let deutschlandLayer;
        let elsassLayer;         
        let elsass1871Layer;               // Choroplethenkarte
        let deutschesReich1871Layer;       // Choroplethenkarte
        let deutschesReich1900Layer;
        let elsassLothringen1900Layer;
        let grenze1900Layer;               // Linienlayer
        let grenzbahnhoefe1900Layer;       // Punktlayer
        let bahnnetzLayer;                 // Linienlayer
        let rheinLayer;                    // dauerhaft sichtbar & Hierachie: oberste Ebene

        // --- Toggle-Layer (Steuerung der Sichtbarkeit über Layer-Control für Zeitpunkt 1) ---
        let elsass1871ToggleLayer;
        let deutschesReich1871ToggleLayer;

        // --- Zeitpunkt 3: Identitätsräume & Kooperationsachsen ---
        let koordinatenMarkerLayer;
        let zeitpunkt3LayerControl;
        let koordinatenToggleLayer;
        let kooperationsachsenLayer;
        let kooperationsachsenToggleLayer;
        let oberrheingrabenLayer;
        let saarLorLuxLayer;

        // ---------------------------------------------------------------------
        // Farbedfinitionen für Identitätsräume
        // Jeder Typ erhält eine eindeutige Farbe für die Darstellung in der Karte (Marker)
        // ---------------------------------------------------------------------
        const identityColors = {
            'Europäisch-institutionell': '#e31a1c',  // Rot
            'Transnational-alltäglich': '#33a02c',   // Grün
            'Regional-kulturell': '#1f78b4'          // Blau
        };

        // ---------------------------------------------------------------------
        // Koordinaten und Informationen zu den Städten für Zeitpunkt 3
        // Enthalten sind: Name, Koordinaten, Typ und Pop-Up-Text
        // ---------------------------------------------------------------------
        const cities = [
            {
                name: 'Straßburg',
                coords: [48.5839, 7.7455],
                type: 'Europäisch-institutionell',
                text: '• Staat: Frankreich<br>• Rolle: Sitz wichtiger EU-Institutionen<br>• Identität: Stark europäisch geprägt, aber weiterhin französisch eingebettet.'
            },
            {
                name: 'Kehl',
                coords: [48.5720, 7.8157],
                type: 'Transnational-alltäglich',
                text: '• Staat: Deutschland<br>• Rolle: Direkte Grenzstadt zu Straßburg<br>• Identität: Alltag stark grenzüberschreitend geprägt.'
            },
            {
                name: 'Karlsruhe',
                coords: [49.0069, 8.4037],
                type: 'Transnational-alltäglich',
                text: '• Staat: Deutschland<br>• Rolle: Sitz wichtiger nationaler Institutionen<br>• Identität: Vorwiegend national, mit europäischer Kooperation.'
            },
            {
                name: 'Colmar',
                coords: [48.0794, 7.3585],
                type: 'Regional-kulturell',
                text: '• Staat: Frankreich<br>• Rolle: Regionales Kulturzentrum im Elsass<br>• Identität: Stark regional geprägt.'
            },
            {
                name: 'Metz',
                coords: [49.1193, 6.1757],
                type: 'Regional-kulturell',
                text: '• Staat: Frankreich<br>• Rolle: Historisch mehrfacher Staatswechsel<br>• Identität: Großregional geprägt durch die Einbindung in die Großregion SaarLorLux.'
            },
            {
                name: 'Saarbrücken',
                coords: [49.2402, 6.9969],
                type: 'Regional-kulturell',
                text: '• Staat: Deutschland<br>• Rolle: Deutscher Knotenpunkt der Großregion SaarLorLux<br>• Identität: Großregional geprägt durch grenzüberschreitende Zusammenarbeit mit Lothringen, Luxemburg und Rheinland-Pfalz'
            }
        ];

        // ---------------------------------------------------------------------
        // CHOROPLETHENFARBSKALA (Stimmungsindex)
        // Farbzuordnung basierend auf den Wert des Stimmungsindex (-3 bis +3)
        // ---------------------------------------------------------------------
        function getChoroplethFillColor(score) {
            if (score === null || score === undefined || Number.isNaN(score)) return '#a4a8aa';
            if (score <= -3) return '#B2182B';
            if (score === -2) return '#D6604D';
            if (score === -1) return '#F4A582';
            if (score === 0) return '#dfcea1';
            if (score === 1) return '#B8E186';
            if (score === 2) return '#4DAC26';
            return '#1B7837';
        }

        // ---------------------------------------------------------------------
        // Wird keine aktive thematische Darstellung verwendet, wird ein neutraler Stil vorgegeben
        // ---------------------------------------------------------------------
        function getNeutralFeatureStyle() {
            return {
                color: '#a4a8aa',
                weight: 1,
                opacity: 1,
                fillColor: '#FFFFFF',
                fillOpacity: 0.5
            };
        }

        // ---------------------------------------------------------------------
        // Stimmungsindex für die Elsass Departements (1871)
        // Zuordnung der Werte für die drei Departements
        // ---------------------------------------------------------------------
        const elsass1871ScoreByDepartment = {
            'MEURTHE-ET-MOSELLE': -3,
            'MEUSE': -3,
            'VOSGES': -2
        };

        // ---------------------------------------------------------------------
        // Darstellung: ELSASS 1871
        // Legt fest, wie die Gebiete visuell dargestellt werden
        // ---------------------------------------------------------------------
        function applyElsass1871Style(isActive) {
            if (!elsass1871Layer) return;

            // Für jedes einzelne Feature (Departement) im Layer
            elsass1871Layer.eachLayer(layer => {
                if (!isActive) {
                    layer.setStyle(getNeutralFeatureStyle());
                    return;
                }
                const dep = String(layer.feature?.properties?.NOM_DEP || '').toUpperCase();
                const score = Object.prototype.hasOwnProperty.call(elsass1871ScoreByDepartment, dep)
                    ? elsass1871ScoreByDepartment[dep]
                    : null;

                // Choroplethenfarbstil anwenden
                layer.setStyle({
                    color: '#a4a8aa',
                    weight: 1,
                    opacity: 1,
                    fillColor: getChoroplethFillColor(score),
                    fillOpacity: 0.7
                });
            });
        }

        // ---------------------------------------------------------------------
        // Darstellung: Deutsches Reich 1871
        // Legt fest, wie die Gebiete visuell dargestellt werden
        // ---------------------------------------------------------------------
        function applyDeutschesReich1871Style(isActive) {
            if (!deutschesReich1871Layer) return;

            deutschesReich1871Layer.eachLayer(layer => {
                if (!isActive) {
                    layer.setStyle(getNeutralFeatureStyle());
                    return;
                }

                const rawScore = layer.feature?.properties?.Stimmungsindex;
                const score = typeof rawScore === 'number' ? rawScore : parseFloat(rawScore);

                layer.setStyle({
                    color: '#a4a8aa',
                    weight: 1,
                    opacity: 1,
                    fillColor: getChoroplethFillColor(score),
                    fillOpacity: 0.7
                });
            });
        }

        // ---------------------------------------------------------------------
        // Darstellung von Zeitpunkt 1 aktualisieren
        // Prüft, welche Layer aktiv sind und passt die Darstellung entsprechend an
        // ---------------------------------------------------------------------
        function syncZeitpunkt1StyleFromControl() {
            const elsassActive = !!(elsass1871ToggleLayer && map.hasLayer(elsass1871ToggleLayer));
            const reichActive = !!(deutschesReich1871ToggleLayer && map.hasLayer(deutschesReich1871ToggleLayer));

            applyElsass1871Style(elsassActive);
            applyDeutschesReich1871Style(reichActive);
        }

        // ---------------------------------------------------------------------
        // Layer Zeitpunkt 1 (1871)
        // Legt fest, welche Layer angezeigt werden und ausgewählt werden
        // Die Grundstruktur dieser Funktion wurde unter Nutzung integrierter Funktionen der Entwicklungsumgebung erstellt und anschließend eigenständig angepasst
        // ---------------------------------------------------------------------
        function refreshZeitpunkt1LayerControl(zeitpunkt) {
            if (layerControl) {
                map.removeControl(layerControl);
                layerControl = null;
            }

            if (zeitpunkt !== 1) {
                if (elsass1871Layer && map.hasLayer(elsass1871Layer)) map.removeLayer(elsass1871Layer);
                if (deutschesReich1871Layer && map.hasLayer(deutschesReich1871Layer)) map.removeLayer(deutschesReich1871Layer);
                if (elsass1871ToggleLayer && map.hasLayer(elsass1871ToggleLayer)) map.removeLayer(elsass1871ToggleLayer);
                if (deutschesReich1871ToggleLayer && map.hasLayer(deutschesReich1871ToggleLayer)) map.removeLayer(deutschesReich1871ToggleLayer);
                if (grenze1900Layer && map.hasLayer(grenze1900Layer)) map.removeLayer(grenze1900Layer);
                if (rheinLayer) rheinLayer.bringToFront(); // Rhein immer ganz oben halten
                return;
            }

            // Zeitpunkt 1:Layer hinzufügen (falls noch nicht aktiv ist)
            if (elsass1871Layer && !map.hasLayer(elsass1871Layer)) map.addLayer(elsass1871Layer);
            if (deutschesReich1871Layer && !map.hasLayer(deutschesReich1871Layer)) map.addLayer(deutschesReich1871Layer);
            if (grenze1900Layer && !map.hasLayer(grenze1900Layer)) map.addLayer(grenze1900Layer);

            // Toggle-Layer als Grundlage für die Auswahl erstellen 
            if (!elsass1871ToggleLayer) elsass1871ToggleLayer = L.layerGroup();
            if (!deutschesReich1871ToggleLayer) deutschesReich1871ToggleLayer = L.layerGroup();

            // Toggle-Layer initial deaktivieren (Checkboxen sind nicht angehakt)
            if (map.hasLayer(elsass1871ToggleLayer)) map.removeLayer(elsass1871ToggleLayer);
            if (map.hasLayer(deutschesReich1871ToggleLayer)) map.removeLayer(deutschesReich1871ToggleLayer);

            // Einträge für die Layer-Auswahl definieren
            const overlays = {};

            if (elsass1871Layer) {
                overlays['Elsass 1871'] = elsass1871ToggleLayer;
            }

            if (deutschesReich1871Layer) {
                overlays['Deutsches Reich 1871'] = deutschesReich1871ToggleLayer;
            }

            // Layer-Control erstellen: Positionierung oben rechts
            layerControl = L.control.layers(null, overlays, {
                position: 'topright',
                collapsed: false
            }).addTo(map);

            // Darstellung wird entsprechend der Auswahl aktualisiert
            syncZeitpunkt1StyleFromControl();

            // Hierachie definiert: Rhein immer im Vordergrund und die anderen Layer darunter
            if (grenze1900Layer) grenze1900Layer.bringToFront();
            if (rheinLayer) rheinLayer.bringToFront();
        }

        // ---------------------------------------------------------------------
        // Darstellung von Zeitpunkt 3 aktualisieren
        // Passt die angezeigten Layer an die aktuelle Auswahl an
        // Die Grundstru
        // ---------------------------------------------------------------------
        function syncZeitpunkt3LayersFromControl() {
            const koordinatenActive = !!(koordinatenToggleLayer && map.hasLayer(koordinatenToggleLayer));
            const achsenActive = !!(kooperationsachsenToggleLayer && map.hasLayer(kooperationsachsenToggleLayer));

            // Identitätsräume ein-/ausblenden
            if (koordinatenMarkerLayer) {
                if (koordinatenActive && !map.hasLayer(koordinatenMarkerLayer)) map.addLayer(koordinatenMarkerLayer);
                if (!koordinatenActive && map.hasLayer(koordinatenMarkerLayer)) map.removeLayer(koordinatenMarkerLayer);
            }

            // Flächen und Linien der Kooperationsachsen ein-/ausblenden
            if (oberrheingrabenLayer) {
                if (achsenActive && !map.hasLayer(oberrheingrabenLayer)) map.addLayer(oberrheingrabenLayer);
                if (!achsenActive && map.hasLayer(oberrheingrabenLayer)) map.removeLayer(oberrheingrabenLayer);
            }

            if (saarLorLuxLayer) {
                if (achsenActive && !map.hasLayer(saarLorLuxLayer)) map.addLayer(saarLorLuxLayer);
                if (!achsenActive && map.hasLayer(saarLorLuxLayer)) map.removeLayer(saarLorLuxLayer);
            }

            if (kooperationsachsenLayer) {
                if (achsenActive && !map.hasLayer(kooperationsachsenLayer)) map.addLayer(kooperationsachsenLayer);
                if (!achsenActive && map.hasLayer(kooperationsachsenLayer)) map.removeLayer(kooperationsachsenLayer);
            }

            // Rhein immer im Vordergrund halten
            if (rheinLayer) rheinLayer.bringToFront();
        }

        // ---------------------------------------------------------------------
        // Layer Zeitpunkt 3 (2026)
        // Legt fest, welche Layer angezeigt werden und wie die Layer ausgewählt werden
        // ---------------------------------------------------------------------
        function refreshZeitpunkt3LayerControl(zeitpunkt) {
            // Bestehende Layer-Auswahl entfernen
            if (zeitpunkt3LayerControl) {
                map.removeControl(zeitpunkt3LayerControl);
                zeitpunkt3LayerControl = null;
            }

            // Wenn nicht Zeitpunkt 3: Alle zugehörigen Layer entfernen
            if (zeitpunkt !== 3) {
                if (deutschlandLayer && map.hasLayer(deutschlandLayer)) map.removeLayer(deutschlandLayer);
                if (elsassLayer && map.hasLayer(elsassLayer)) map.removeLayer(elsassLayer);
                if (koordinatenMarkerLayer && map.hasLayer(koordinatenMarkerLayer)) map.removeLayer(koordinatenMarkerLayer);
                if (kooperationsachsenLayer && map.hasLayer(kooperationsachsenLayer)) map.removeLayer(kooperationsachsenLayer);
                if (oberrheingrabenLayer && map.hasLayer(oberrheingrabenLayer)) map.removeLayer(oberrheingrabenLayer);
                if (saarLorLuxLayer && map.hasLayer(saarLorLuxLayer)) map.removeLayer(saarLorLuxLayer);
                if (koordinatenToggleLayer && map.hasLayer(koordinatenToggleLayer)) map.removeLayer(koordinatenToggleLayer);
                if (kooperationsachsenToggleLayer && map.hasLayer(kooperationsachsenToggleLayer)) map.removeLayer(kooperationsachsenToggleLayer);
                if (rheinLayer) rheinLayer.bringToFront();
                return;
            }

            // Hintergrund-Layer anzeigen
            if (deutschlandLayer && !map.hasLayer(deutschlandLayer)) map.addLayer(deutschlandLayer);
            if (elsassLayer && !map.hasLayer(elsassLayer)) map.addLayer(elsassLayer);

            // Toggle-Layer erstellen (falls noch nicht vorhanden)
            if (!koordinatenToggleLayer) koordinatenToggleLayer = L.layerGroup();
            if (!kooperationsachsenToggleLayer) kooperationsachsenToggleLayer = L.layerGroup();

            // Standardzustand festgelegt
            if (!map.hasLayer(koordinatenToggleLayer)) map.addLayer(koordinatenToggleLayer);
            if (map.hasLayer(kooperationsachsenToggleLayer)) map.removeLayer(kooperationsachsenToggleLayer);

            // Einträge für die Layer-Auswahl definieren
            const overlays = {};
            if (koordinatenMarkerLayer) overlays['Identit\u00e4tsr\u00e4ume'] = koordinatenToggleLayer;
            if (kooperationsachsenLayer) overlays['Kooperationsachsen'] = kooperationsachsenToggleLayer;

            // Layer-Control definieren; Positionierung oben rechts
            zeitpunkt3LayerControl = L.control.layers(null, overlays, {
                position: 'topright',
                collapsed: false
            }).addTo(map);

            // Darstellung entsprechend der Auswahl aktualisieren
            syncZeitpunkt3LayersFromControl();

            if (rheinLayer) rheinLayer.bringToFront();
        }

        // ---------------------------------------------------------------------
        // Layer Zeitpunkt 2 (ca. 1900)
        // Blendet die zugehörigen Layer ein oder aus
        // ---------------------------------------------------------------------
        function refreshZeitpunkt2Layers(zeitpunkt) {
            const show1900Layers = zeitpunkt === 2; // Nur bei Zeitpunkt 2 anzeigen

            // Deutsches Reich 1900
            if (deutschesReich1900Layer) {
                if (show1900Layers && !map.hasLayer(deutschesReich1900Layer)) map.addLayer(deutschesReich1900Layer);
                if (!show1900Layers && map.hasLayer(deutschesReich1900Layer)) map.removeLayer(deutschesReich1900Layer);
            }

            // Elsass-Lothringen 1900
            if (elsassLothringen1900Layer) {
                if (show1900Layers && !map.hasLayer(elsassLothringen1900Layer)) map.addLayer(elsassLothringen1900Layer);
                if (!show1900Layers && map.hasLayer(elsassLothringen1900Layer)) map.removeLayer(elsassLothringen1900Layer);
            }

            // Staatsgrenze 1900: Wird auch bei Zeitpunkt 1 angezeigt
            if (grenze1900Layer) {
                if ((show1900Layers || zeitpunkt === 1) && !map.hasLayer(grenze1900Layer)) map.addLayer(grenze1900Layer);
                if (!show1900Layers && zeitpunkt !== 1 && map.hasLayer(grenze1900Layer)) map.removeLayer(grenze1900Layer);
            }

            // Grenzbahnhöfe 1900
            if (grenzbahnhoefe1900Layer) {
                if (show1900Layers && !map.hasLayer(grenzbahnhoefe1900Layer)) map.addLayer(grenzbahnhoefe1900Layer);
                if (!show1900Layers && map.hasLayer(grenzbahnhoefe1900Layer)) map.removeLayer(grenzbahnhoefe1900Layer);
            }

            // Bahnnetz
            if (bahnnetzLayer) {
                if (show1900Layers && !map.hasLayer(bahnnetzLayer)) map.addLayer(bahnnetzLayer);
                if (!show1900Layers && map.hasLayer(bahnnetzLayer)) map.removeLayer(bahnnetzLayer);
            }

            // Rhein immer im Vordergrund
            if (rheinLayer) rheinLayer.bringToFront();
        }

        // ---------------------------------------------------------------------
        // Infobox für Zeitpunkt 1 (1871)
        // ---------------------------------------------------------------------
        function refreshZeitpunkt1InfoBox(zeitpunkt) {
            // Bestehende Infobox entfernen
            if (zeitpunkt1InfoControl) {
                map.removeControl(zeitpunkt1InfoControl);
                zeitpunkt1InfoControl = null;
            }

            // Nur bei Zeitpunkt 1 anzeigen
            if (zeitpunkt !== 1) return;

            zeitpunkt1InfoControl = L.control({ position: 'topleft' });
            zeitpunkt1InfoControl.onAdd = function () {
                const div = L.DomUtil.create('div', 'legend-box');
                div.innerHTML =
                    '<strong style="font-size:14px;">1871 – Grenze als politische Trennlinie</strong>' +
                    '<div style="margin-top:4px;"><strong>Annexion und Grenzverschiebung</strong></div>' +
                    '<div style="margin-top:4px;">Nach dem Deutsch-Französischen Krieg wird Elsass-Lothringen Teil des Deutschen Reiches.<br>Die neue Staatsgrenze verläuft nun entlang des Rheins und schafft eine klare politische Trennung zwischen beiden Staaten.</div>' +
                    '<div style="margin-top:8px;">Der Stimmungsindex zeigt deutliche regionale Unterschiede in der Haltung zur Annexion.<br>Der Grenzraum wird damit zu einer politisch geprägten Konfliktzone, in der nationale Zugehörigkeit stark umstritten ist.</div>';

                L.DomEvent.disableClickPropagation(div);
                return div;
            };

            zeitpunkt1InfoControl.addTo(map);
        }

        // ---------------------------------------------------------------------
        // Infobox für Zeitpunkt 2 (ca. 1900)
